unreachable_while_loop: () -> s32 =
{
    while false
    {
        return 10;
    }

    return 20;
}

redundant_while_loop: () -> s32 =
{
    while true
    {
        return 10;
    }

    return 20;
}

redundant_continue: () -> void =
{
    a: mutable _ = 10;
    while a > 0
    {
        a = a - 1;
        continue; // TODO(vlad): Emit warning about redundant 'continue' statement?
    }
}

while_loops: () -> void =
{
    while false {}

    a: mutable _ = 10;
    while a > 0
    {
        a = a - 1;
    }

    b: mutable _ = 20;
    while true
    {
        b = b - 1;
        if b < 0
        {
            break;
        }
    }
}
