simple_reassignment: () -> void =
{
    a: mutable _ = 10;
    a = 20;
}

parameter_reassignment: (parameter: mutable s32) -> void =
{
    parameter = 20;
}

returning_value_from_a_function: () -> s32 =
{
    a := 10;
    return a;
}

returning_mutable_value_from_a_function: () -> s32 =
{
    a: mutable _ = 10;
    a = 20;
    a = 30;
    return a;
}

simple_conditional_assignment: () -> s32 =
{
    a: mutable _ = 10;

    if 1 == 2
    {
        a = 20;
    }

    return a;
}

conditional_assignment_of_multiple_variables: () -> s32 =
{
    a: mutable _ = 10;
    b: mutable _ = 11;

    if 1 == 2
    {
        a = 20;
        b = 21;
    }
    else
    {
        a = 30;
    }

    return a + b;
}

function_calls: () -> s32 =
{
    simple_reassignment();

    a := returning_value_from_a_function();
    parameter_reassignment(a);

    return returning_value_from_a_function();
}
