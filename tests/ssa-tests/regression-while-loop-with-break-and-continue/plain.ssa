regression_while_loop_with_break_and_continue:
     1 |           ASSIGN           VARIABLE c@1, CONSTANT s32 20
       |
       |           PHI              VARIABLE c@2, VARIABLE c@1, VARIABLE c@3
     2 | LABEL_1:
     3 |           EQUAL            VARIABLE <temp_1>@1, CONSTANT s32 1, CONSTANT s32 1
     4 |           JUMP_IF_FALSE    LABEL_2, VARIABLE <temp_1>@1
     5 |           SUBTRACT         VARIABLE <temp_2>@1, VARIABLE c@2, CONSTANT s32 1
     6 |           ASSIGN           VARIABLE c@3, VARIABLE <temp_2>@1
     7 |           GREATER_OR_EQUAL VARIABLE <temp_3>@1, VARIABLE c@3, CONSTANT s32 0
     8 |           JUMP_IF_FALSE    LABEL_3, VARIABLE <temp_3>@1
     9 |           JUMP             LABEL_1
    10 | LABEL_3:
    11 | LABEL_4:
    12 |           JUMP             LABEL_2
       |
       |           PHI              VARIABLE c@4, VARIABLE c@2, VARIABLE c@3
    13 | LABEL_2:
    14 |           RETURN
